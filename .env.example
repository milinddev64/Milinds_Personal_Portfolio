VITE_CONTENTFUL_SPACE_ID=
VITE_CONTENTFUL_ACCESS_TOKEN=

# Google AdSense
# Get your Publisher ID from https://adsense.google.com → Account → Account information
# Format: ca-pub-XXXXXXXXXXXXXXXX
# Leave blank or remove this line until your AdSense account is approved
VITE_ADSENSE_CLIENT_ID=


# EmailJS Configuration
# Get these values from https://dashboard.emailjs.com/

# Service ID - Found in Email Services section
VITE_EMAILJS_SERVICE_ID=

# Template ID - Found in Email Templates section
VITE_EMAILJS_TEMPLATE_ID=

# Public Key - Found in Account > General section
VITE_EMAILJS_PUBLIC_KEY=
